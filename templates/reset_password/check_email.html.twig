{% extends 'base.html.twig' %}

{% block title %}Email envoyé{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Vérifiez votre messagerie</h1>

        <p>
            Si un compte correspondant à cette adresse email existe, un email contenant un lien de réinitialisation vient d’être envoyé.
        </p>

        <p>
            Ce lien expirera dans
            {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
        </p>

        <p>
            Si vous ne recevez pas d’email, pensez à vérifier vos courriers indésirables
            ou <a href="{{ path('app_forgot_password_request') }}">réessayez</a>.
        </p>
    </div>
{% endblock %}