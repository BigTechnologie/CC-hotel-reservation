{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
    <div class="container mt-4">
        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="alert alert-danger" role="alert">
                {{ flash_error }}
            </div>
        {% endfor %}

        <h1>Mot de passe oublié</h1>

        <p>
            Saisissez votre adresse email. Si un compte existe, un lien de réinitialisation vous sera envoyé.
        </p>

        {{ form_start(requestForm) }}
            {{ form_row(requestForm.email) }}

            <button class="btn btn-primary">Envoyer le lien de réinitialisation</button>
        {{ form_end(requestForm) }}
    </div>
{% endblock %}